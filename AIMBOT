-- SMOOTH
local smoothLabel = Instance.new("TextLabel", main)
smoothLabel.Position = UDim2.new(0.05,0,0,140)
smoothLabel.Size = UDim2.new(0.9,0,0,20)
smoothLabel.Text = "SMOOTH: "..smoothness
smoothLabel.TextColor3 = Color3.new(1,1,1)
smoothLabel.BackgroundTransparency = 1

local smoothBar = Instance.new("Frame", main)
